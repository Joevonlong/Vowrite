#!/usr/bin/env bash
# Vowrite pre-commit hook
# Generated by review charter v1, 2026-05-15
#
# Install: git config core.hooksPath .githooks
#
# Behavior:
#   ① gitleaks  — ALWAYS runs, cannot be skipped. Secret detection is a hard security gate.
#   ② swiftlint — Only staged .swift files; only ERROR level blocks commit (warnings pass through).
#   ③ swift-format — Lint report only, never blocks, never auto-rewrites.
#
# Skip ②③ (lint only): SKIP=lint git commit
# There is NO way to skip ① gitleaks.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SKIP_LINT=false

if [[ "${SKIP:-}" == *lint* ]]; then
    SKIP_LINT=true
fi

# ─────────────────────────────────────────────────────────────────────────────
# ① GITLEAKS — hard security gate, always runs, cannot be skipped via SKIP
# ─────────────────────────────────────────────────────────────────────────────
echo "🔍 [pre-commit] Running gitleaks secret scan (always on)..."

if command -v gitleaks &>/dev/null; then
    if ! gitleaks protect --staged --redact --config="${REPO_ROOT}/.gitleaks.toml" 2>&1; then
        echo ""
        echo "❌ [pre-commit] gitleaks detected a potential secret in staged files."
        echo "   Commit blocked. Review the output above, remove the secret, and re-stage."
        echo "   NOTE: This check cannot be bypassed with SKIP=lint."
        exit 1
    fi
    echo "✅ [pre-commit] gitleaks: no secrets detected."
else
    echo "⚠️  [pre-commit] gitleaks not found — falling back to grep-based scan."
    # Lightweight fallback: grep staged content for obvious key patterns
    STAGED_PATCH="$(git diff --cached --unified=0 2>/dev/null || true)"
    LEAK_HITS=""

    if echo "$STAGED_PATCH" | grep -qE '^\+.*sk-[A-Za-z0-9]{20,}'; then
        LEAK_HITS="${LEAK_HITS}\n  - Possible OpenAI key (sk-...)"
    fi
    if echo "$STAGED_PATCH" | grep -qE '^\+.*gsk_[A-Za-z0-9]{30,}'; then
        LEAK_HITS="${LEAK_HITS}\n  - Possible Groq key (gsk_...)"
    fi
    if echo "$STAGED_PATCH" | grep -qE '^\+.*sk-ant-[A-Za-z0-9\-]{30,}'; then
        LEAK_HITS="${LEAK_HITS}\n  - Possible Anthropic key (sk-ant-...)"
    fi
    if echo "$STAGED_PATCH" | grep -qE '^\+.*GOCSPX-[A-Za-z0-9_\-]{20,}'; then
        LEAK_HITS="${LEAK_HITS}\n  - Possible Google OAuth secret (GOCSPX-...)"
    fi
    if echo "$STAGED_PATCH" | grep -qE '^\+.*-----BEGIN[^-]*PRIVATE KEY-----'; then
        LEAK_HITS="${LEAK_HITS}\n  - Private key PEM block detected"
    fi

    if [[ -n "$LEAK_HITS" ]]; then
        echo ""
        echo "❌ [pre-commit] Possible secrets detected in staged changes (grep fallback):"
        echo -e "$LEAK_HITS"
        echo "   Install gitleaks for accurate scanning: brew install gitleaks"
        exit 1
    fi
    echo "✅ [pre-commit] grep fallback: no obvious secrets detected."
fi

# ─────────────────────────────────────────────────────────────────────────────
# ② SWIFTLINT — staged .swift files only; only ERROR level blocks
# ─────────────────────────────────────────────────────────────────────────────
if $SKIP_LINT; then
    echo "⏭  [pre-commit] Lint skipped (SKIP=lint). Note: gitleaks still ran."
    exit 0
fi

# Collect staged .swift files
STAGED_SWIFT_FILES=()
while IFS= read -r -d '' f; do
    STAGED_SWIFT_FILES+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACMR -z | grep -z '\.swift$' || true)

if [[ ${#STAGED_SWIFT_FILES[@]} -eq 0 ]]; then
    echo "ℹ️  [pre-commit] No staged .swift files — lint checks skipped."
    exit 0
fi

echo "🔎 [pre-commit] SwiftLint: scanning ${#STAGED_SWIFT_FILES[@]} staged .swift file(s)..."
echo "   (Only ERROR level violations block commit; warnings are informational.)"

if command -v swiftlint &>/dev/null; then
    # Run swiftlint on staged files only, capture output
    LINT_OUTPUT=""
    LINT_OUTPUT=$(swiftlint lint --quiet --config "${REPO_ROOT}/.swiftlint.yml" "${STAGED_SWIFT_FILES[@]}" 2>&1 || true)

    ERROR_LINES=$(echo "$LINT_OUTPUT" | grep ' error:' || true)
    WARNING_LINES=$(echo "$LINT_OUTPUT" | grep ' warning:' || true)

    if [[ -n "$WARNING_LINES" ]]; then
        echo "⚠️  [pre-commit] SwiftLint warnings (informational, not blocking):"
        echo "$WARNING_LINES" | head -20
        WARN_COUNT=$(echo "$WARNING_LINES" | wc -l | tr -d ' ')
        [[ "$WARN_COUNT" -gt 20 ]] && echo "   ... and $((WARN_COUNT - 20)) more warnings."
    fi

    if [[ -n "$ERROR_LINES" ]]; then
        echo ""
        echo "❌ [pre-commit] SwiftLint ERRORS found (commit blocked):"
        echo "$ERROR_LINES"
        echo ""
        echo "   Fix the errors above, re-stage, and commit again."
        echo "   To skip lint checks (not recommended): SKIP=lint git commit"
        exit 1
    fi

    echo "✅ [pre-commit] SwiftLint: no errors in staged files."
else
    echo "⚠️  [pre-commit] swiftlint not found — skipping SwiftLint check."
    echo "   Install: brew install swiftlint"
fi

# ─────────────────────────────────────────────────────────────────────────────
# ③ SWIFT-FORMAT — lint report only, never blocks, never auto-rewrites
# ─────────────────────────────────────────────────────────────────────────────
echo "🖊️  [pre-commit] swift-format lint (report only, never blocks)..."

if command -v swift-format &>/dev/null; then
    FORMAT_OUTPUT=""
    for f in "${STAGED_SWIFT_FILES[@]}"; do
        FORMAT_OUTPUT+=$(swift-format lint --configuration "${REPO_ROOT}/.swift-format" "$f" 2>&1 || true)
    done

    if [[ -n "$FORMAT_OUTPUT" ]]; then
        echo "ℹ️  [pre-commit] swift-format issues (informational):"
        echo "$FORMAT_OUTPUT" | head -20
    else
        echo "✅ [pre-commit] swift-format: no issues."
    fi
else
    echo "⚠️  [pre-commit] swift-format not found — skipping format check."
    echo "   Install: brew install swift-format"
fi

echo ""
echo "✅ [pre-commit] All checks complete. Proceeding with commit."
exit 0
