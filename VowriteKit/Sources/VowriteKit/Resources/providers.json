{
  "version": 1,
  "providers": [
    {
      "id": "openai",
      "name": "OpenAI",
      "baseURL": "https://api.openai.com/v1",
      "isOpenAICompatible": true,
      "auth": {
        "style": "bearer",
        "keyPlaceholder": "sk-...",
        "keyURL": "https://platform.openai.com/api-keys",
        "requiresKey": true
      },
      "capabilities": { "stt": true, "polish": true },
      "sttAdapter": "openai-compatible",
      "stt": {
        "defaultModel": "gpt-4o-mini-transcribe",
        "models": [
          { "id": "gpt-4o-mini-transcribe", "description": "Fast and low-cost" },
          { "id": "gpt-4o-transcribe", "description": "Highest OpenAI quality" },
          { "id": "whisper-1", "description": "Classic Whisper endpoint" }
        ]
      },
      "polish": {
        "defaultModel": "gpt-4o-mini",
        "models": [
          { "id": "gpt-4o-mini", "description": "Balanced quality and speed" },
          { "id": "gpt-4o", "description": "Highest quality" }
        ]
      }
    },
    {
      "id": "openrouter",
      "name": "OpenRouter",
      "baseURL": "https://openrouter.ai/api/v1",
      "isOpenAICompatible": true,
      "auth": {
        "style": "bearer",
        "keyPlaceholder": "sk-or-...",
        "keyURL": "https://openrouter.ai/keys",
        "requiresKey": true
      },
      "capabilities": { "stt": false, "polish": true },
      "sttNote": "OpenRouter does not proxy the Whisper transcription API.",
      "headers": {
        "HTTP-Referer": "https://vowrite.com",
        "X-Title": "Vowrite"
      },
      "stt": {
        "defaultModel": "openai/whisper-large-v3",
        "models": []
      },
      "polish": {
        "defaultModel": "openai/gpt-4o-mini",
        "models": []
      }
    },
